# Optional: if unset, web server will infer repo root from working directory.
ULTRASOUND_REPO_ROOT=

# Next.js dev server port.
PORT=3100

# Optional: override local ai-worker endpoint for future phases.
AI_WORKER_URL=http://127.0.0.1:8001
AI_RUNNER_MODE=mock

# Used in later phase (/file admin auth)
ADMIN_USER=admin
ADMIN_PASSWORD=change-me
